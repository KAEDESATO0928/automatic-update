{
  "manifest_version": 3,
  "name": "Carrier Entry Automation",
  "version": "1.1.0",
  "description": "kintoneデータを通信キャリア申込サイトへ自動入力するChrome拡張機能",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://because-i.cybozu.com/*",
    "https://www.so-net.ne.jp/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.so-net.ne.jp/*"],
      "js": ["scripts/content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "config/mapping.json",
        "scripts/errors.js",
        "scripts/log-manager.js"
      ],
      "matches": ["https://www.so-net.ne.jp/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
